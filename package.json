{
  "name": "agent-swarm",
  "version": "1.0.0",
  "description": "A multi-mode AI agent harness with router, dynamic review, and extension system",
  "main": "dist/harness.js",
  "bin": {
    "agent": "bin/agent.js"
  },
  "exports": {
    ".": "./dist/harness.js",
    "./config": "./dist/config.js",
    "./models": "./dist/models.js",
    "./agents": "./dist/agents/index.js"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx --watch src/cli.ts",
    "start": "node bin/agent.js"
  },
  "keywords": [
    "ai",
    "agent",
    "mastra",
    "cli",
    "router"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@mastra/core": "^1.36.0",
    "@mastra/libsql": "^1.11.1",
    "@mastra/memory": "^1.19.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
